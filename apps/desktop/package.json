{
  "name": "@werb/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build ../../crates/werb-beerxml-wasm --target web --out-dir pkg --release",
    "dev": "pnpm build:wasm && vite",
    "build": "pnpm build:wasm && tsc -b && vite build",
    "preview": "vite preview",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "pnpm build:wasm && tauri dev",
    "tauri:build": "pnpm build:wasm && tauri build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.0",
    "@tauri-apps/api": "^2.1.0",
    "@tauri-apps/plugin-dialog": "^2.1.0",
    "@tauri-apps/plugin-fs": "^2.1.0",
    "@werb/adapters": "workspace:*",
    "@werb/calc": "workspace:*",
    "@werb/types": "workspace:*",
    "@werb/validate": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/dom": "^10",
    "@testing-library/react": "^16",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "happy-dom": "^15",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.3.0"
  }
}
