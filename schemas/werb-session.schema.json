{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://werb.dev/schemas/werb-session.schema.json",
  "title": "WerbSession",
  "description": "A live record of a brew day. References a source recipe by ID and freezes a snapshot of it at session start so later edits to the recipe don't mutate the brew log.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "recipe_id", "status", "started_at", "steps"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique session ID (typically a UUID or ISO timestamp)."
    },
    "recipe_id": {
      "type": "string",
      "description": "Pointer to the source recipe (the LoadedRecipe.id, which is a file basename in v0)."
    },
    "recipe_name": {
      "type": "string",
      "description": "Human-readable recipe name, copied for offline display when the recipe file is unavailable."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "in_progress", "completed", "abandoned"]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/SessionStep" }
    },
    "measurements": {
      "type": "array",
      "items": { "$ref": "#/$defs/Measurement" },
      "description": "Point-in-time readings logged during the brew. Optional in v0 (no UI yet)."
    },
    "notes": {
      "type": "string"
    },
    "tasting": {
      "$ref": "#/$defs/Tasting",
      "description": "Post-brew sensory evaluation. Filled in once the beer is ready to drink — recorded against the session so each brew of the same recipe has its own tasting history."
    }
  },
  "$defs": {
    "SessionStep": {
      "title": "SessionStep",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "label", "status"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": [
            "prepare_water",
            "mash_in",
            "mash",
            "sparge",
            "boil",
            "hop_addition",
            "whirlpool",
            "chill",
            "transfer",
            "ferment_pitch",
            "custom"
          ]
        },
        "label": {
          "type": "string",
          "description": "Short human-readable label (e.g. 'Saccharification', 'Mosaic 30g flameout')."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "active", "done", "skipped"]
        },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "target_duration_min": {
          "type": "number",
          "description": "Planned duration. The Brew screen shows it as a countdown when the step is active."
        },
        "target_temperature_c": { "type": "number" },
        "notes": { "type": "string" }
      }
    },
    "Measurement": {
      "title": "Measurement",
      "type": "object",
      "additionalProperties": false,
      "required": ["at", "kind", "value"],
      "properties": {
        "at": { "type": "string", "format": "date-time" },
        "kind": {
          "type": "string",
          "enum": ["temperature_c", "gravity_sg", "ph", "volume_l", "abv_pct"]
        },
        "value": { "type": "number" },
        "step_id": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "Tasting": {
      "title": "Tasting",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tasted_at",
        "axes",
        "overall_rating"
      ],
      "properties": {
        "tasted_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the brewer tasted the beer (typically 2-6 weeks after package, depending on the style)."
        },
        "axes": {
          "$ref": "#/$defs/SensoryAxes",
          "description": "7-axis sensory profile, rendered as a radar chart on the recipe and journal screens. Each axis is 0-5; 0 means 'absent', 5 means 'pronounced'."
        },
        "overall_rating": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "Stars. 1 = drain pour, 5 = world class."
        },
        "notes": {
          "type": "string",
          "description": "Free-form tasting notes — aroma observations, what worked, what to change next time."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Short labels surfaced as chips on the recipe screen so future brews see concrete lessons (e.g. 'too bitter', 'great head', 'oxidation', 'best one yet')."
        }
      }
    },
    "SensoryAxes": {
      "title": "SensoryAxes",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bitterness",
        "sweetness",
        "sourness",
        "hop_character",
        "malt_character",
        "body",
        "carbonation"
      ],
      "properties": {
        "bitterness": { "type": "number", "minimum": 0, "maximum": 5 },
        "sweetness": { "type": "number", "minimum": 0, "maximum": 5 },
        "sourness": { "type": "number", "minimum": 0, "maximum": 5 },
        "hop_character": {
          "type": "number",
          "minimum": 0,
          "maximum": 5,
          "description": "Combined hop aroma + flavor — how much hop expression is present in the glass, irrespective of bitterness."
        },
        "malt_character": {
          "type": "number",
          "minimum": 0,
          "maximum": 5,
          "description": "Maltiness — bready, biscuity, caramel, roast. Style-dependent baseline."
        },
        "body": {
          "type": "number",
          "minimum": 0,
          "maximum": 5,
          "description": "Mouthfeel weight — thin to full. Not the same as gravity."
        },
        "carbonation": {
          "type": "number",
          "minimum": 0,
          "maximum": 5,
          "description": "Perceived carbonation — flat to highly effervescent."
        }
      }
    }
  }
}
